<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Habit Cost Calculator | ToolGarden</title>
  <meta name="description" content="See how much a recurring habit costs over time and how many work hours it eats." />
  <style>
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; width: 100%; min-height: 100%; }
    body {
      font-family: Arial, sans-serif;
      color: #2f241d;
      overflow-x: hidden;
      position: relative;
      background:
        radial-gradient(circle at top left, rgba(255, 197, 109, 0.52), transparent 28%),
        radial-gradient(circle at bottom right, rgba(255, 130, 64, 0.34), transparent 32%),
        linear-gradient(180deg, #f2dcc4 0%, #e3c3a8 100%);
    }
    .page-wrap {
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      position: relative;
      z-index: 2;
    }
    .background {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: 0;
    }
    .background span {
      position: absolute;
      bottom: -140px;
      font-size: 2.5rem;
      opacity: 0.30;
      animation: floatUp linear infinite;
      user-select: none;
      text-shadow: 0 4px 18px rgba(255, 255, 255, 0.14);
    }
    .background span:nth-child(1)  { left: 3%;  animation-duration: 16s; animation-delay: 0s; }
    .background span:nth-child(2)  { left: 10%; animation-duration: 20s; animation-delay: 3s; }
    .background span:nth-child(3)  { left: 18%; animation-duration: 17s; animation-delay: 1s; }
    .background span:nth-child(4)  { left: 26%; animation-duration: 22s; animation-delay: 5s; }
    .background span:nth-child(5)  { left: 34%; animation-duration: 18s; animation-delay: 2s; }
    .background span:nth-child(6)  { left: 42%; animation-duration: 21s; animation-delay: 6s; }
    .background span:nth-child(7)  { left: 50%; animation-duration: 17s; animation-delay: 4s; }
    .background span:nth-child(8)  { left: 58%; animation-duration: 23s; animation-delay: 1.5s; }
    .background span:nth-child(9)  { left: 66%; animation-duration: 19s; animation-delay: 4.5s; }
    .background span:nth-child(10) { left: 74%; animation-duration: 24s; animation-delay: 2.5s; }
    .background span:nth-child(11) { left: 82%; animation-duration: 18s; animation-delay: 6.5s; }
    .background span:nth-child(12) { left: 90%; animation-duration: 21s; animation-delay: 3.5s; }
    @keyframes floatUp {
      0% { transform: translateY(0) rotate(0deg) scale(0.96); opacity: 0; }
      8% { opacity: 0.30; }
      70% { opacity: 0.30; }
      100% { transform: translateY(-128vh) rotate(360deg) scale(1.08); opacity: 0; }
    }
    .glow, .glow2 {
      position: fixed;
      width: 380px;
      height: 380px;
      border-radius: 50%;
      filter: blur(135px);
      opacity: 0.36;
      z-index: 0;
      pointer-events: none;
    }
    .glow { background: #ffb347; top: 4%; left: 4%; }
    .glow2 { background: #ff8748; bottom: 4%; right: 4%; }
    .card {
      width: 100%;
      max-width: 760px;
      background: linear-gradient(180deg, rgba(255, 243, 228, 0.98) 0%, rgba(252, 232, 212, 0.96) 100%);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 25px;
      padding: 30px 20px;
      text-align: center;
      box-shadow: 0 20px 60px rgba(83, 49, 18, 0.15), inset 0 1px 0 rgba(255,255,255,0.34);
      border: 2px solid rgba(234, 88, 12, 0.26);
      position: relative;
      z-index: 3;
    }
    .tool-switcher {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }
    .tool-link {
      display: inline-block;
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid rgba(234, 88, 12, 0.24);
      background: rgba(255,255,255,0.55);
      color: #8a4a24;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
    }
    .tool-link.active {
      background: linear-gradient(135deg, #f15a08, #ca430d);
      color: #fff;
      border-color: transparent;
    }
    .top-emoji { font-size: 2rem; margin-bottom: 8px; }
    h1 { margin: 0; font-size: 26px; line-height: 1.15; color: #2f241d; }
    .subtitle {
      color: #6a5648;
      margin: 15px 0 25px;
      line-height: 1.5;
      font-size: 15px;
    }
    .form-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      text-align: left;
    }
    .input-label {
      display: block;
      font-weight: 700;
      font-size: 15px;
      margin-bottom: 10px;
      color: #5c4638;
    }
    input, select {
      width: 100%;
      padding: 14px;
      font-size: 16px;
      border-radius: 12px;
      border: 1px solid rgba(214, 132, 74, 0.34);
      background: linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,248,241,0.92) 100%);
      color: #2f241d;
    }
    button {
      width: 100%;
      padding: 14px;
      margin-top: 18px;
      background: linear-gradient(135deg, #f15a08, #ca430d);
      color: white;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: 12px;
      cursor: pointer;
    }
    .result-box {
      margin-top: 20px;
      padding: 24px 18px 18px;
      border-radius: 22px;
      background: linear-gradient(145deg, #fff8f3 0%, #ffe6d5 45%, #ffd7bf 100%);
      border: 2px solid rgba(234, 88, 12, 0.30);
      text-align: left;
    }
    .result {
      font-size: 22px;
      font-weight: 800;
      color: #b94814;
      line-height: 1.2;
      text-align: center;
    }
    .subtext {
      margin-top: 10px;
      color: #665f59;
      font-size: 14px;
      line-height: 1.45;
      text-align: center;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 16px;
    }
    .stat-card {
      padding: 14px;
      border-radius: 16px;
      background: rgba(255,255,255,0.5);
      border: 1px solid rgba(234, 88, 12, 0.16);
    }
    .stat-title {
      font-weight: 800;
      color: #8d4517;
      font-size: 14px;
      margin-bottom: 6px;
    }
    .stat-text {
      color: #6a5648;
      font-size: 14px;
      line-height: 1.5;
    }
    .footer {
      margin-top: 22px;
      font-size: 12px;
      color: #a79b92;
      line-height: 1.8;
      text-align: center;
    }
    .footer a {
      color: #a35a35;
      text-decoration: none;
      font-weight: 700;
      margin: 0 5px;
    }
    @media (min-width: 700px) {
      .form-grid,
      .stats-grid {
        grid-template-columns: 1fr 1fr;
      }
      .wide {
        grid-column: 1 / -1;
      }
    }
  </style>
</head>
<body>
  <div class="background">
    <span>⏳</span>
    <span>💸</span>
    <span>☕</span>
    <span>🚬</span>
    <span>💄</span>
    <span>🍔</span>
    <span>💳</span>
    <span>🧠</span>
    <span>✨</span>
    <span>🧾</span>
    <span>💼</span>
    <span>💰</span>
  </div>

  <div class="glow"></div>
  <div class="glow2"></div>

  <div class="page-wrap">
    <div class="card">
      <div class="tool-switcher">
        <a class="tool-link" href="index.html">Home</a>
        <a class="tool-link" href="eating-out.html">Eating Out</a>
        <a class="tool-link" href="coffee.html">Coffee Runs</a>
        <a class="tool-link" href="subscriptions.html">Subscriptions</a>
        <a class="tool-link active" href="habit-cost.html">Habit Cost</a>
      </div>

      <div class="top-emoji">⏳💸</div>
      <h1>Habit Cost Calculator</h1>
      <p class="subtitle">
        Pick a habit, enter what it costs, and see the money and work hours it eats over time.
      </p>

      <div class="form-grid">
        <div>
          <label class="input-label" for="habitType">Habit type</label>
          <select id="habitType">
            <option value="coffee">Coffee</option>
            <option value="fastFood">Fast Food</option>
            <option value="vape">Vape / Cigs</option>
            <option value="makeup">Makeup / Beauty</option>
            <option value="custom">Custom</option>
          </select>
        </div>

        <div>
          <label class="input-label" for="costPerUse">Cost per purchase / use</label>
          <input type="number" id="costPerUse" placeholder="Example: 8.50" />
        </div>

        <div>
          <label class="input-label" for="timesPerWeek">How many times per week?</label>
          <input type="number" id="timesPerWeek" placeholder="Example: 5" />
        </div>

        <div>
          <label class="input-label" for="hourlyWage">Hourly wage</label>
          <input type="number" id="hourlyWage" placeholder="Example: 15" />
        </div>
      </div>

      <button onclick="calculateHabit()">Show me the damage</button>

      <div class="result-box">
        <div class="result" id="result">Your total will show here</div>
        <div class="subtext" id="subtext">Small habits have a sneaky talent for becoming annual plot twists.</div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-title">Weekly cost</div>
            <div class="stat-text" id="weeklyCost">Your weekly total will show here.</div>
          </div>
          <div class="stat-card">
            <div class="stat-title">Monthly cost</div>
            <div class="stat-text" id="monthlyCost">Your monthly total will show here.</div>
          </div>
          <div class="stat-card">
            <div class="stat-title">Yearly cost</div>
            <div class="stat-text" id="yearlyCost">Your yearly total will show here.</div>
          </div>
          <div class="stat-card">
            <div class="stat-title">Hours worked</div>
            <div class="stat-text" id="hoursWorked">Your work-hours reality check will show here.</div>
          </div>
        </div>
      </div>

      <div class="footer">
        ToolGarden • tiny tools, big realizations<br><br>
        <a href="index.html">Home</a> •
        <a href="about.html">About</a> •
        <a href="privacy.html">Privacy</a> •
        <a href="terms.html">Terms</a> •
        <a href="contact.html">Contact</a>
      </div>
    </div>
  </div>

  <script>
    function money(num) {
      return `$${num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    }

    function calculateHabit() {
      const habitType = document.getElementById("habitType").value;
      const costPerUse = Number(document.getElementById("costPerUse").value);
      const timesPerWeek = Number(document.getElementById("timesPerWeek").value);
      const hourlyWage = Number(document.getElementById("hourlyWage").value);

      if (!costPerUse || !timesPerWeek || costPerUse < 0 || timesPerWeek <= 0) {
        document.getElementById("result").innerText = "Enter real numbers 👀";
        document.getElementById("subtext").innerText = "Try your honest cost and frequency.";
        document.getElementById("weeklyCost").innerText = "Your weekly total will show here.";
        document.getElementById("monthlyCost").innerText = "Your monthly total will show here.";
        document.getElementById("yearlyCost").innerText = "Your yearly total will show here.";
        document.getElementById("hoursWorked").innerText = "Your work-hours reality check will show here.";
        return;
      }

      const weekly = costPerUse * timesPerWeek;
      const monthly = weekly * 4.33;
      const yearly = weekly * 52;
      const hours = hourlyWage > 0 ? yearly / hourlyWage : 0;

      const labels = {
        coffee: "coffee habit",
        fastFood: "fast food habit",
        vape: "vape / cigarette habit",
        makeup: "beauty spending habit",
        custom: "habit"
      };

      document.getElementById("result").innerText = `${money(yearly)} per year 😬`;
      document.getElementById("subtext").innerText = `Your ${labels[habitType]} adds up faster than it feels in the moment.`;
      document.getElementById("weeklyCost").innerText = `${money(weekly)} every week.`;
      document.getElementById("monthlyCost").innerText = `${money(monthly)} per month.`;
      document.getElementById("yearlyCost").innerText = `${money(yearly)} every year.`;
      document.getElementById("hoursWorked").innerText = hourlyWage > 0
        ? `That is about ${hours.toFixed(1)} hours of work.`
        : `Add your hourly wage to see how many work hours this costs.`;
    }
  </script>
</body>
</html>
